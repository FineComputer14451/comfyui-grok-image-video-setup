# --- Core ComfyUI ---
INSTALL_CUSTOM_NODES=0
INSTALL_WAN_WRAPPER=0

# Prebuilt image (hosted / pull mode). CI publishes:
#   ghcr.io/finecomputer14451/comfyui-grok-build:latest
IMAGE=comfyui-grok-build:latest

# --- Hosted reverse proxy (docker-compose.hosted.yml) ---
HOSTED_DOMAIN=localhost
HOSTED_EMAIL=admin@example.com
HOSTED_BASIC_USER=grok
# Generate:
#   docker run --rm caddy:2.9-alpine caddy hash-password --plaintext 'your-password'
HOSTED_BASIC_HASH=
HOSTED_HTTP_PORT=80
HOSTED_HTTPS_PORT=443

# Optional Cloudflare Tunnel token (enables profile "tunnel")
CLOUDFLARE_TUNNEL_TOKEN=
